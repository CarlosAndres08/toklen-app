# ================================
# 🔒 INSTRUCCIONES DE SEGURIDAD
# ================================
# 1. NUNCA subas el archivo .env a Git
# 2. Cambia JWT_SECRET por una clave única y segura
# 3. En producción, usa variables de entorno del servidor
# 4. Mantén las credenciales de BD seguras
# ================================

# Configuración para Desarrollo Local
NODE_ENV=development
PORT=5000

# Base de Datos PostgreSQL Local (Variables Individuales - Más Seguro)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=toklen_bd
DB_USER=toklen_user
DB_PASSWORD=Carandre08

# Base de Datos PostgreSQL (URL Completa - Para Producción)
# DATABASE_URL=postgresql://toklen_user:Carandre08@localhost:5432/toklen_bd

# JWT Secret (cambia esto por una clave segura)
JWT_SECRET=tu_jwt_secret_muy_seguro_aqui_2024

# Stripe (usa las claves de prueba)
STRIPE_SECRET_KEY=sk_test_tu_clave_secreta_de_stripe
STRIPE_PUBLISHABLE_KEY=pk_test_tu_clave_publica_de_stripe

# Firebase Admin (opcional para desarrollo local)
FIREBASE_PROJECT_ID=tu_proyecto_firebase
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_PRIVATE_KEY_AQUI\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu_proyecto.iam.gserviceaccount.com

# CORS Origins (para desarrollo local)
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100