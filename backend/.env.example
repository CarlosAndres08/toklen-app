# ==============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ==============================================

# Para desarrollo local
DB_HOST=localhost
DB_PORT=5432
DB_NAME=toklen_bd
DB_USER=toklen_user
DB_PASSWORD=tu_password_aqui

# Para producción (Render, Railway, etc.)
# DATABASE_URL=postgresql://usuario:password@host:puerto/database

# ==============================================
# CONFIGURACIÓN DE FIREBASE ADMIN
# ==============================================

FIREBASE_ADMIN_PROJECT_ID=tu-proyecto-firebase
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\ntu_clave_privada_aqui\n-----END PRIVATE KEY-----\n"
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com

# ==============================================
# CONFIGURACIÓN DE STRIPE (PAGOS)
# ==============================================

STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxx

# ==============================================
# CONFIGURACIÓN DE JWT
# ==============================================

JWT_SECRET=tu_jwt_secret_muy_seguro_aqui_minimo_32_caracteres
JWT_EXPIRES_IN=7d

# ==============================================
# CONFIGURACIÓN DE CORS Y FRONTEND
# ==============================================

FRONTEND_URL=http://localhost:5173
# Para producción: FRONTEND_URL=https://tu-app.vercel.app

# ==============================================
# CONFIGURACIÓN DEL SERVIDOR
# ==============================================

PORT=5000
NODE_ENV=development

# ==============================================
# CONFIGURACIÓN DE SEGURIDAD
# ==============================================

# Clave para encriptación adicional (opcional)
ENCRYPTION_KEY=tu_clave_de_encriptacion_32_caracteres

# ==============================================
# CONFIGURACIÓN DE EMAIL (OPCIONAL)
# ==============================================

# Para notificaciones por email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-app-password

# ==============================================
# CONFIGURACIÓN DE ALMACENAMIENTO (OPCIONAL)
# ==============================================

# Para subida de archivos (AWS S3, Cloudinary, etc.)
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# ==============================================
# CONFIGURACIÓN DE LOGS Y MONITOREO
# ==============================================

# Nivel de logs (error, warn, info, debug)
LOG_LEVEL=info

# Para servicios como Sentry (opcional)
SENTRY_DSN=https://xxxxxxxxx@sentry.io/xxxxxxx

