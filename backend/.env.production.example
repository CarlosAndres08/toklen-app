# Variables de Entorno para Producción (Render)
# NO subir este archivo a Git - solo para referencia

# Configuración básica
NODE_ENV=production
PORT=10000

# Base de datos (se configura automáticamente desde Render)
DATABASE_URL=postgresql://toklen_user:password@host:5432/toklen_bd

# Variables individuales de BD (alternativa más segura)
DB_HOST=your_production_host
DB_PORT=5432
DB_NAME=toklen_bd
DB_USER=toklen_user
DB_PASSWORD=your_secure_production_password

# JWT Secret (se genera automáticamente en Render)
JWT_SECRET=jwt_secret_super_seguro_para_produccion

# CORS
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Firebase Admin SDK (configurar manualmente en Render Dashboard)
FIREBASE_PROJECT_ID=tu-proyecto-firebase
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_PRIVATE_KEY_COMPLETA_AQUI\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com

# Stripe (configurar manualmente en Render Dashboard)
STRIPE_SECRET_KEY=sk_live_tu_clave_secreta_de_produccion
STRIPE_PUBLISHABLE_KEY=pk_live_tu_clave_publica_de_produccion

# Frontend URL
FRONTEND_URL=https://toklen.vercel.app

