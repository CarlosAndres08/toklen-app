# ==============================================
# CONFIGURACIÓN DE LA API BACKEND
# ==============================================

# URL del backend en desarrollo
VITE_API_URL=http://localhost:5000/api

# URL del backend en producción
# VITE_API_URL=https://tu-backend.render.com/api

# ==============================================
# CONFIGURACIÓN DE FIREBASE (CLIENTE)
# ==============================================

VITE_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456789012

# ==============================================
# CONFIGURACIÓN DE STRIPE (CLIENTE)
# ==============================================

# Clave pública de Stripe (segura para el frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_51234567890abcdef

# ==============================================
# CONFIGURACIÓN DE GOOGLE MAPS
# ==============================================

# API Key de Google Maps para el frontend
VITE_GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ==============================================
# CONFIGURACIÓN DE ANALYTICS (OPCIONAL)
# ==============================================

# Google Analytics
VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# ==============================================
# CONFIGURACIÓN DE ENTORNO
# ==============================================

# Modo de desarrollo o producción
VITE_NODE_ENV=development

# Habilitar logs de debug en desarrollo
VITE_DEBUG=true

# ==============================================
# CONFIGURACIÓN DE FEATURES FLAGS (OPCIONAL)
# ==============================================

# Habilitar/deshabilitar características específicas
VITE_ENABLE_PAYMENTS=true
VITE_ENABLE_CHAT=false
VITE_ENABLE_NOTIFICATIONS=true

# ==============================================
# CONFIGURACIÓN DE TERCEROS (OPCIONAL)
# ==============================================

# Para servicios de chat como Intercom, Zendesk, etc.
VITE_INTERCOM_APP_ID=xxxxxxxx

# Para servicios de error tracking como Sentry
VITE_SENTRY_DSN=https://xxxxxxxxx@sentry.io/xxxxxxx

